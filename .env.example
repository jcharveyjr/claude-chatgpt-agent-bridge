# This file is auto-loaded at startup when present (Node >= 20.12).
# Override the path with AGENT_BRIDGE_ENV_FILE, or export these vars directly.

# Required when HTTP binds to anything other than 127.0.0.1 or ::1.
AGENT_BRIDGE_TOKEN=replace-with-a-long-random-token

# Optional overrides.
AGENT_BRIDGE_CONFIG=./bridge.config.json
AGENT_BRIDGE_HOST=127.0.0.1
AGENT_BRIDGE_PORT=8787
AGENT_BRIDGE_ALLOWED_ORIGINS=https://chatgpt.com,https://claude.ai

# Hosted OAuth/JWT mode. When these are all set, JWT validation replaces the
# static AGENT_BRIDGE_TOKEN check. Use values from your OAuth provider.
# AGENT_BRIDGE_PUBLIC_URL=https://bridge.example.com
# AGENT_BRIDGE_OAUTH_ISSUER=https://your-tenant.example.com/
# AGENT_BRIDGE_OAUTH_AUDIENCE=https://bridge.example.com/mcp
# AGENT_BRIDGE_OAUTH_JWKS_URL=https://your-tenant.example.com/.well-known/jwks.json
# AGENT_BRIDGE_OAUTH_SCOPES=agent_bridge:delegate
