{
  "name": "claude-chatgpt-agent-bridge",
  "version": "0.1.10",
  "description": "A vendor-neutral MCP task broker for delegated work between Claude and Codex/ChatGPT agents.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:stdio": "tsx src/cli.ts stdio",
    "dev:http": "tsx src/cli.ts http",
    "start:stdio": "node dist/src/cli.js stdio",
    "start:http": "node dist/src/cli.js http",
    "status": "node dist/src/cli.js status",
    "start:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/start-agent-bridge.ps1",
    "stop:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/stop-agent-bridge.ps1",
    "setup:local": "node scripts/setup-local.mjs",
    "doctor": "node scripts/doctor.mjs",
    "smoke:http": "node scripts/smoke-http.mjs",
    "coverage": "node --test --experimental-test-coverage --test-coverage-exclude=test/** --test-coverage-lines=70 --test-coverage-branches=65 --test-coverage-functions=70 --test-timeout=60000 --import tsx test/*.test.ts",
    "sync:skills": "node scripts/sync-skills.mjs",
    "test": "node --test --test-timeout=60000 --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "jose": "6.2.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "license": "MIT"
}
